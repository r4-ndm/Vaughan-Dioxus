{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Shell UI, dApp iframes, and allow-listed HTTPS origins may invoke the wallet IPC bridge and allowlisted main-webview navigation (parity with wallet state.json + browser.rs).",
  "windows": ["main", "warm-slot-*"],
  "permissions": [
    "core:default",
    "allow-ipc-request",
    "allow-spike-ping",
    "allow-navigate-trusted-dapp"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1/*",
      "http://127.0.0.1:*/*",
      "http://localhost/*",
      "http://localhost:*/*",
      "https://uniswap.org/*",
      "https://*.uniswap.org/*",
      "https://uniswap.com/*",
      "https://*.uniswap.com/*",
      "https://sushi.com/*",
      "https://*.sushi.com/*",
      "https://pancakeswap.finance/*",
      "https://*.pancakeswap.finance/*",
      "https://curve.fi/*",
      "https://*.curve.fi/*",
      "https://aave.com/*",
      "https://*.aave.com/*",
      "https://compound.finance/*",
      "https://*.compound.finance/*",
      "https://1inch.com/*",
      "https://*.1inch.com/*",
      "https://opensea.io/*",
      "https://*.opensea.io/*",
      "https://stargate.finance/*",
      "https://*.stargate.finance/*",
      "https://v4.testnet.pulsechain.com/*",
      "https://*.v4.testnet.pulsechain.com/*",
      "https://pulsex.com/*",
      "https://*.pulsex.com/*",
      "https://pulsex.mypinata.cloud/*",
      "https://*.pulsex.mypinata.cloud/*",
      "https://piteas.io/*",
      "https://*.piteas.io/*",
      "https://gopulse.com/*",
      "https://*.gopulse.com/*",
      "https://internetmoney.io/*",
      "https://*.internetmoney.io/*",
      "https://provex.com/*",
      "https://*.provex.com/*",
      "https://libertyswap.finance/*",
      "https://*.libertyswap.finance/*",
      "https://0xcurv.win/*",
      "https://*.0xcurv.win/*",
      "https://pump.tires/*",
      "https://*.pump.tires/*",
      "https://9mm.pro/*",
      "https://*.9mm.pro/*",
      "https://9inch.io/*",
      "https://*.9inch.io/*",
      "https://hyperliquid.xyz/*",
      "https://*.hyperliquid.xyz/*",
      "https://asterdex.com/*",
      "https://*.asterdex.com/*"
    ]
  }
}
